Function EncryptColumnarImproved(Const Text, Key: String): String;
Var
    CleanText, CleanKey: String;
    ColCount, I, J, PosText: Integer;
    Order: Array Of Integer;
    Matrix: Array Of Array Of Char;
    RowLengths: Array Of Integer;
Begin
    CleanText := CleanEnglish(Text);
    CleanKey := CleanEnglish(Key);

    ColCount := Length(CleanKey);
    If ColCount = 0 Then
        Exit('');

    SetLength(Order, ColCount);

    For I := 0 To ColCount - 1 Do
        Order[I] := 0;

    For I := 0 To ColCount - 1 Do
        For J := 0 To ColCount - 1 Do
            If (CleanKey[J + 1] < CleanKey[I + 1]) Or
                ((CleanKey[J + 1] = CleanKey[I + 1]) And (J < I)) Then
                Inc(Order[I]);

    PosText := 1;
    SetLength(RowLengths, ColCount);
    SetLength(Matrix, ColCount, ColCount);

    For I := 0 To ColCount - 1 Do
        For J := 0 To ColCount - 1 Do
            Matrix[I][J] := #0;

    For I := 0 To ColCount - 1 Do
    Begin
        For J := 0 To ColCount - 1 Do
            If Order[J] = I Then
            Begin
                RowLengths[I] := J;
                Break;
            End;
        For J := 0 To RowLengths[I] Do
        Begin
            If PosText <= Length(CleanText) Then
            Begin
                Matrix[I][J] := CleanText[PosText];
                Inc(PosText);
            End
            Else
                Matrix[I][J] := #0;
        End;
    End;

    Result := '';
    For I := 0 To ColCount - 1 Do
        For J := 0 To ColCount - 1 Do
            If Order[J] = I Then
                For PosText := 0 To ColCount - 1 Do
                    If Not (Matrix[PosText][J] = #0) Then
                        Result := Result + Matrix[PosText][J];
End;

