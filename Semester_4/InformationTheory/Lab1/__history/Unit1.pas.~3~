Function CleanRussian(Const S: String): String;
Var
    I: Integer;
Begin
    Result := '';
    For I := 1 To Length(S) Do
    Begin
        If (S[I] >= 'Ŕ') And (S[I] <= 'ß') Or (S[I] = '¨') Then
            Result := Result + S[I];
    End;
End;

