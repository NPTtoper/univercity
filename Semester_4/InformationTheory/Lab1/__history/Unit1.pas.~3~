Function CleanEnglish(Const S: String): String;
Var
    I: Integer;
Begin
    Result := '';
    For I := 1 To Length(S) Do
    Begin
        If (S[I] >= 'A') And (S[I] <= 'Z') Then
            Result := Result + S[I];
    End;
End;

