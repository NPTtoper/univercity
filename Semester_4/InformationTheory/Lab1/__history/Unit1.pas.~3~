Function DecryptColumnarImproved(Const Text, Key: String): String;
Var
    CleanText, CleanKey: String;
    ColCount, I, J, K, PosText: Integer;
    Order: Array Of Integer;
    Matrix: Array Of Array Of Char;
    MatrixTrue: Array Of Array Of Boolean;
    RowLengths: Array Of Integer;
Begin
    CleanText := CleanEnglish(Text);
    CleanKey := CleanEnglish(Key);

    ColCount := Length(CleanKey);
    If ColCount = 0 Then
        Exit('');

    SetLength(Matrix, ColCount, ColCount);
    SetLength(MatrixTrue, ColCount, ColCount);
    SetLength(RowLengths, ColCount);

    For I := 0 To ColCount - 1 Do
        For J := 0 To ColCount - 1 Do
            MatrixTrue[I][J] := False;

    SetLength(Order, ColCount);

    For I := 0 To ColCount - 1 Do
        Order[I] := 0;

    For I := 0 To ColCount - 1 Do
        For J := 0 To ColCount - 1 Do
            If (CleanKey[J + 1] < CleanKey[I + 1]) Or
                ((CleanKey[J + 1] = CleanKey[I + 1]) And (J < I)) Then
                Inc(Order[I]);

    For I := 0 To ColCount - 1 Do
    Begin
        For J := 0 To ColCount - 1 Do
            If Order[J] = I Then
            Begin
                RowLengths[I] := J;
                Break;
            End;
        For J := 0 To RowLengths[I] Do
        Begin
            MatrixTrue[I][J] := True;
        End;
    End;

    Result := '';

    PosText := 1;
    For I := 0 To ColCount - 1 Do
        For J := 0 To ColCount - 1 Do
            If Order[J] = I Then
                For K := 0 To ColCount - 1 Do
                    If MatrixTrue[K][J] And (PosText < Length(CleanText)) Then
                    Begin
                        Matrix[K][J] := CleanText[PosText];
                        Inc(PosText);
                    End;

    For I := 0 To ColCount - 1 Do
        For J := 0 To RowLengths[I] Do
            Result := Result + Matrix[I][J];
End;

